<!DOCTYPE html>
<html lang="pt-br">

<head>
<meta charset="UTF-8">
<title>Lofi Focus</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
font-family:Arial;
color:white;
overflow:hidden;
}



.video-bg{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
object-fit:cover;
z-index:-2;
}



.overlay{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.4);
z-index:-1;
}


.clock {
    position: absolute; 
    top: 30px;         
    right: 30px;        
    
    font-size: 32px;    
    font-weight: 300;   
    letter-spacing: 2px;
    
    color: rgba(255, 255, 255, 0.9); 
    background: rgba(0, 0, 0, 0.3);
    padding: 15px 25px;
    border-radius: 12px;
    backdrop-filter: blur(8px);
    
    border: 1px solid rgba(255, 255, 255, 0.1); 
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}
.quote{
    font-family:'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif ;
    font-style: oblique;
    font-weight: 540;
    text-shadow: blur(10%);
    text-shadow: rgb(206, 206, 206);
    font-size: 18px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: rgba(223, 216, 216, 0.6);
    font-weight: 300;
    position: absolute;
    bottom: 40px;
    width: 90%;
    text-align: center;
}
</style>
</head>

<body>
<div class="quote" id="quote">Focus on your journey.</div>
<video class="video-bg" autoplay muted loop>
<source src="video.mp4" type="video/mp4">
</video>

<div class="overlay"></div>

<div class="clock" id="clock">
00:00:00
</div>

<script>

let timeLeft = 25 * 60; // 25 minutos em segundos

function updateClock() {
    let minutes = Math.floor(timeLeft / 60);
    let seconds = timeLeft % 60;

    minutes = minutes.toString().padStart(2, "0");
    seconds = seconds.toString().padStart(2, "0");

    document.getElementById("clock").textContent = `${minutes}:${seconds}`;

    if (timeLeft > 0) {
        timeLeft--;
    } else {
        document.getElementById("clock").textContent = "PAUSE";
    }
}

setInterval(updateClock, 1000);

updateClock()

</script>

</body>
</html>
